# ═══════════════════════════════════════════════════════════════
# Backend environment
# ═══════════════════════════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/smart_home

# Redis
REDIS_URL=redis://:redispass@localhost:6379

# MQTT broker (Aedes chạy local qua `npm run broker`)
MQTT_URL=mqtt://localhost:1883
MQTT_USER=smarthome
MQTT_PASS=matkhau123

# Định danh device (khớp với ESP32 firmware, DEVICE_ID + API_KEY + HMAC_SECRET ở đầu src/main.cpp)
DEVICE_ID=smarthome-phn-7f3a
API_KEY=sk-smarthome-7f3a9d2e
# HMAC-SHA256 secret — dùng ký/verify chữ ký sig trên mọi message MQTT (không bao giờ truyền qua mạng)
HMAC_SECRET=hmac-secret-phn-2b8c4e6f

# JWT (lớp user login — không liên quan tới IoT layer)
JWT_SECRET=change_me_in_production_a_very_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=change_me_in_production_another_long_random_string_at_least_64_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Passkey / WebAuthn
RP_ID=localhost
RP_NAME=Smart Home Dashboard
RP_ORIGIN=http://localhost:5173

# Password pepper (bcrypt input pepper)
PASSWORD_PEPPER=change_me_static_pepper_string
